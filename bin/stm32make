#!/bin/bash
# stm32make — STM32 project generator v1.2
# Usage: stm32make <command> [options]
# Chip support: F103C8, F103RCT6, F103VE, F407VG

CMD=$1; shift

# ── Language detection ──
# Chinese if LANG/LC_ALL starts with "zh" AND charset contains UTF
LANG_ZH=0
LOCALE="${LC_ALL:-$LANG}"
if [[ "$LOCALE" =~ ^[Zz][Hh] ]] && [[ "$LOCALE" =~ [Uu][Tt][Ff] ]]; then
    LANG_ZH=1
fi

# Print bi-lingual message: p "中文" "English"
p() { [ "$LANG_ZH" = "1" ] && echo "$1" || echo "$2"; }
pf() { [ "$LANG_ZH" = "1" ] && printf "$1" "${@:3}" || printf "$2" "${@:3}"; }

# ── Helpers ──

detect_serial_group() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        [ "$ID" = "arch" ] && echo "uucp" || echo "dialout"
    else
        echo "dialout"
    fi
}

SERIAL_GROUP=$(detect_serial_group)

# ── Help ──
show_help() {
echo "stm32make v1.2 — STM32 project generator & flasher"
echo "Usage: stm32make <command> [options]"
echo ""
echo "Commands:"
p "  new <name> <chip>     新建项目" "  new <name> <chip>     Create a new project"
p "  flash [opts] [file]   自动检测设备并烧录" "  flash [opts] [file]   Auto-detect & flash"
p "  list                  列出可用芯片" "  list                  List supported chips"
p "  doctor                诊断开发环境" "  doctor                Diagnose development environment"
p "  update                从GitHub获取最新版" "  update                Update from GitHub"
p "  help, -h, --help      显示此帮助" "  help, -h, --help      Show this help"
echo ""
p "flash 选项:" "flash options:"
p "  --use-reset          启用硬件复位（需接NRST线）" "  --use-reset          Enable hardware reset (NRST required)"
echo ""
echo "Examples:"
echo "  stm32make new led-blink F103C8"
echo "  cd led-blink && cmake -B build && cmake --build build"
echo "  stm32make flash"
echo "  stm32make doctor"
echo "  stm32make update"
}

# ── Find toolkit root ──
find_toolkit() {
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    for dir in "$SCRIPT_DIR/../stm32-toolkit" "$SCRIPT_DIR/.." "$HOME/stm32-toolkit" "$HOME/.local/share/stm32-toolkit" "$(dirname "$SCRIPT_DIR")"; do
        [ -d "$dir/templates" ] && { echo "$dir"; return 0; }
    done
    return 1
}

case "$CMD" in

# ── new ──
new)
    NAME=$1; CHIP=$2; USE_SPL=""
    for arg in "$@"; do
        [ "$arg" = "--spl" ] && USE_SPL="yes"
    done
    NAME=$1; CHIP=$2
    [ -z "$NAME" ] && { p "用法: stm32make new 项目名 [芯片型号] [--spl]" "Usage: stm32make new <name> <chip> [--spl]"; exit 1; }
    : ${CHIP:=F103C8}

    # 芯片名带 -spl 后缀时自动启用 SPL 模式
    case "$CHIP" in
        *-spl) USE_SPL="yes"; CHIP="${CHIP%-spl}" ;;
    esac

    TEMPLATE_NAME="$CHIP"
    [ -n "$USE_SPL" ] && TEMPLATE_NAME="${CHIP}-spl"

    TOOLKIT_DIR=$(find_toolkit)
    [ -z "$TOOLKIT_DIR" ] && { p "❌ 找不到模板目录" "❌ Template directory not found"; exit 1; }
    TEMPLATE_DIR="$TOOLKIT_DIR/templates/$TEMPLATE_NAME"

    if [ -d "$TEMPLATE_DIR" ]; then
        cp -r "$TEMPLATE_DIR" "$NAME"
        find "$NAME" -type f -exec sed -i "s/__PROJECT_NAME__/$NAME/g" {} \;

        if [ -n "$USE_SPL" ]; then
            mkdir -p "$NAME/Drivers/CMSIS" "$NAME/Drivers/SPL"
            cp -r "$TOOLKIT_DIR/packs/CMSIS/"* "$NAME/Drivers/CMSIS/"
            cp -r "$TOOLKIT_DIR/packs/STM32F1_SPL/"* "$NAME/Drivers/SPL/"
            p "✅ 已导入 CMSIS + SPL 库文件到 Drivers/" "✅ CMSIS + SPL imported to Drivers/"
        fi

        pf "✅ 项目 %s (%s) 已创建\n" "✅ Project %s (%s) created\n" "$NAME" "$CHIP"
        echo "   Build:  cd $NAME && cmake -B build && cmake --build build"
        echo "   Flash:  st-flash --connect-under-reset write build/$NAME.bin 0x08000000"
        p "   如果接了NRST线: st-flash --connect-under-reset --reset write build/$NAME.bin 0x08000000" "   With NRST: st-flash --connect-under-reset --reset write build/$NAME.bin 0x08000000"
        echo "   Or use:  stm32make flash"
    else
        p "❌ 不支持的芯片: $CHIP" "❌ Unsupported chip: $CHIP"
        p "   可用: $(ls "$TOOLKIT_DIR/templates" 2>/dev/null | tr '\\\\n' ' ')" "   Available: $(ls "$TOOLKIT_DIR/templates" 2>/dev/null | tr '\\\\n' ' ')"
        exit 1
    fi
    ;;

# ── list ──
list)
    TOOLKIT_DIR=$(find_toolkit)
    if [ -z "$TOOLKIT_DIR" ]; then
        p "❌ 找不到模板目录" "❌ Template directory not found"
        exit 1
    fi
    p "可用芯片模板:" "Available chip templates:"
    for d in "$TOOLKIT_DIR/templates"/*/; do
        [ -d "$d" ] && echo "  - $(basename "$d")"
    done
    ;;

# ── flash ──
flash)
    USE_RESET=""
    for arg in "$@"; do
        [ "$arg" = "--use-reset" ] && USE_RESET="yes"
    done

    BIN=""
    for arg in "$@"; do
        case "$arg" in
            -* ) ;;
            * ) [ -z "$BIN" ] && BIN="$arg" ;;
        esac
    done

    if [ -z "$BIN" ]; then
        BIN=$(ls build/*.bin 2>/dev/null | head -1)
    fi
    if [ -z "$BIN" ] || [ ! -f "$BIN" ]; then
        p "❌ 找不到 .bin 文件" "❌ No .bin file found"
        p "   用法: stm32make flash [--use-reset] [build/文件.bin]" "   Usage: stm32make flash [--use-reset] [build/app.bin]"
        exit 1
    fi

    p "🔍 检测烧录设备..." "🔍 Detecting programmer..."

    if command -v st-info &>/dev/null && st-info --probe 2>/dev/null | grep -q "Found [1-9]"; then
        p "✅ 检测到 ST-Link" "✅ ST-Link detected"
        if [ -n "$USE_RESET" ]; then
            p "   (启用硬件复位: --use-reset)" "   (hardware reset: --use-reset)"
            st-flash --connect-under-reset --reset write "$BIN" 0x08000000
        else
            st-flash --connect-under-reset write "$BIN" 0x08000000
        fi
        exit $?
    fi

    PORTS=$(ls /dev/ttyUSB* /dev/ttyACM* 2>/dev/null)
    if [ -z "$PORTS" ]; then
        p "❌ 未检测到任何烧录设备" "❌ No programmer detected"
        echo ""
        p "   请检查:" "   Check:"
        echo "   1. ST-Link plugged into USB?"
        p "   2. VMware → VM → Removable Devices → 连接设备" "   2. VMware → VM → Removable Devices → Connect"
        p "   3. 串口ISP: 检查 /dev/ttyUSB* 是否存在" "   3. Serial ISP: check /dev/ttyUSB*"
        p "   4. 权限: sudo usermod -aG $SERIAL_GROUP \$USER (然后重登)" "   4. Permissions: sudo usermod -aG $SERIAL_GROUP \$USER (then re-login)"
        exit 1
    fi

    COUNT=$(echo "$PORTS" | wc -l)
    if [ "$COUNT" -gt 1 ]; then
        p "⚠️  检测到多个串口设备:" "⚠️  Multiple serial devices:"
        i=1
        for p in $PORTS; do
            echo "   $i) $p"
            i=$((i+1))
        done
        p -n "选择设备 (1-$COUNT): " "Select device (1-$COUNT): "
        read -r SEL
        PORT=$(echo "$PORTS" | sed -n "${SEL}p")
        [ -z "$PORT" ] && { p "❌ 无效选择" "❌ Invalid selection"; exit 1; }
    else
        PORT=$PORTS
    fi

    p "✅ 使用 $PORT" "✅ Using $PORT"

    if [ ! -r "$PORT" ]; then
        p "⚠️  需要串口权限" "⚠️  Serial port permission denied"
        p "   尝试: sudo usermod -aG $SERIAL_GROUP \$USER" "   Try: sudo usermod -aG $SERIAL_GROUP \$USER"
        p "   或运行: newgrp $SERIAL_GROUP" "   Or: newgrp $SERIAL_GROUP"
        echo ""
        p "   用 sudo 临时烧录..." "   Flashing with sudo..."
        sudo stm32flash -b 115200 -w "$BIN" -g 0x0 "$PORT"
    else
        stm32flash -b 115200 -w "$BIN" -g 0x0 "$PORT"
    fi
    ;;

# ── doctor ──
doctor)
    p "🔍 STM32 Toolkit 环境诊断" "🔍 STM32 Toolkit Diagnostics"
    echo ""

    # OS
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "ℹ️  OS:                $NAME $VERSION_ID"
    else
        p "ℹ️  OS:                (未知)" "ℹ️  OS:                (unknown)"
    fi
    echo "ℹ️  Kernel:            $(uname -r)"

    # arm-none-eabi-gcc
    if command -v arm-none-eabi-gcc &>/dev/null; then
        VER=$(arm-none-eabi-gcc --version | head -1 | grep -oP '[\d]+\.[\d]+\.[\d]+')
        echo "✅ arm-none-eabi-gcc  found  ($VER)"
    else
        p "❌ arm-none-eabi-gcc  MISSING  (需要安装)" "❌ arm-none-eabi-gcc  MISSING"
    fi

    # cmake
    if command -v cmake &>/dev/null; then
        VER=$(cmake --version | head -1 | grep -oP '[\d]+\.[\d]+\.[\d]+')
        echo "✅ cmake              found  ($VER)"
    else
        p "❌ cmake              MISSING  (需要安装)" "❌ cmake              MISSING"
    fi

    # st-flash
    if command -v st-flash &>/dev/null; then
        VER=$(st-flash --version 2>&1 | head -1 | grep -oP '[\d]+\.[\d]+\.[\d]+' || echo "?")
        echo "✅ st-flash           found  ($VER)"
    else
        p "❌ st-flash           MISSING  (需要安装 stlink-tools)" "❌ st-flash           MISSING (install stlink-tools)"
    fi

    # stm32flash
    if command -v stm32flash &>/dev/null; then
        echo "✅ stm32flash         found"
    else
        p "❌ stm32flash         MISSING  (可选，串口ISP烧录用)" "❌ stm32flash         MISSING (optional, for serial ISP)"
    fi

    # udev rules
    if ls /etc/udev/rules.d/*stlink* &>/dev/null; then
        echo "✅ udev rules         present  (ST-Link)"
    else
        p "⚠️  udev rules         MISSING  (ST-Link需要配置)" "⚠️  udev rules         MISSING (ST-Link requires udev)"
    fi

    # serial group
    if groups | grep -qE "\b($SERIAL_GROUP|dialout|uucp)\b"; then
        p "✅ 串口权限           OK  (用户已在 $SERIAL_GROUP 组)" "✅ Serial group        OK  (user in $SERIAL_GROUP)"
    else
        p "⚠️  串口权限          需要修复" "⚠️  Serial group       needs fix"
        p "   运行: sudo usermod -aG $SERIAL_GROUP \$USER" "   Run: sudo usermod -aG $SERIAL_GROUP \$USER"
        p "   然后重新登录" "   Then re-login or reboot"
    fi

    # templates
    TOOLKIT_DIR=$(find_toolkit)
    if [ -n "$TOOLKIT_DIR" ]; then
        COUNT=$(ls -d "$TOOLKIT_DIR/templates"/*/ 2>/dev/null | wc -l)
        p "✅ 芯片模板           找到 $COUNT 个" "✅ Chip templates      $COUNT found"
    else
        p "⚠️  芯片模板          未找到 (stm32make new 将无法工作)" "⚠️  Chip templates      not found (stm32make new won't work)"
    fi

    # python3
    if command -v python3 &>/dev/null; then
        VER=$(python3 --version 2>&1 | grep -oP '[\d]+\.[\d]+\.[\d]+')
        echo "✅ python3             found  ($VER)"
    else
        p "❌ python3             MISSING  (需要安装)" "❌ python3             MISSING"
    fi
    ;;

# ── update ──
update)
    TOOLKIT_DIR=$(find_toolkit)
    if [ -z "$TOOLKIT_DIR" ]; then
        p "❌ 找不到 stm32-toolkit 仓库目录" "❌ stm32-toolkit repository not found"
        exit 1
    fi

    if [ ! -d "$TOOLKIT_DIR/.git" ]; then
        p "❌ $TOOLKIT_DIR 不是 git 仓库，无法更新" "❌ $TOOLKIT_DIR is not a git repo"
        p "   请重新克隆: git clone https://github.com/HIKARIZG1102/stm32-toolkit.git" "   Re-clone: git clone https://github.com/HIKARIZG1102/stm32-toolkit.git"
        exit 1
    fi

    p "📥 正在检查更新..." "📥 Checking for updates..."
    cd "$TOOLKIT_DIR" || exit 1

    OLD_VER=$(head -2 bin/stm32make | grep -oP 'v[\d]+\.[\d]+')

    git pull --ff-only 2>&1 || {
        p "❌ git pull 失败" "❌ git pull failed"
        p "   可能有本地修改未提交，或网络问题" "   Local changes not committed, or network issue"
        exit 1
    }

    NEW_VER=$(head -2 bin/stm32make | grep -oP 'v[\d]+\.[\d]+')

    if [ "$OLD_VER" != "$NEW_VER" ]; then
        p "✅ 已更新: $OLD_VER → $NEW_VER" "✅ Updated: $OLD_VER → $NEW_VER"
    else
        p "✅ 已是最新版 ($OLD_VER)" "✅ Already up to date ($OLD_VER)"
    fi
    ;;

# ── help ──
help|-h|--help)
    show_help
    exit 0
    ;;

*)
    show_help
    ;;
esac
